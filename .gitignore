### # System & OS Junk
# Folders/files generated by the OS that add no value to the code

.DS_Store
Thumbs.db
*.lnk
*.dmg
*.iso

### # Compiled Source & Binaries
# Large binaries and object files that should be rebuilt from source

*.com
*.class
*.dll
*.exe
*.o
*.obj
*.so
*.out
*.pyc
*.bin

### # Libraries & Static Archives

*.a
*.lib
*.la
*.lai
*.slo
*.lo

### # Packages & Compressed Files
# Better to commit source; Git handles its own compression

*.7z
*.gz
*.rar
*.tar
*.zip
*.jar

### # Build Directories & Precompiled Headers
# Keeps your workspace clean from temporary build artifacts

build/
dist/
bin/
obj/
*.gch
*.pch
*.d
*.mod
*.smod

### # Logs, Databases & Temporary Files
# Prevents sensitive data or massive log files from leaking

*.log
*.sql
*.sqlite
*.tmp
*.bak
*.csv
*.old
*.fb

### # IDE & Tooling Configuration
# Local environment settings that shouldn't be shared with the team

.vscode/
.vs/
.idea/
*.swp
*.swo
.env
.terraform/

### # Dependency Folders
# These should be managed by package managers, not Git

node_modules/
venv/
.venv/
env/
**pycache**/
